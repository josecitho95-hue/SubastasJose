# =============================================================================
# SubastasGeek — PLANTILLA DE VARIABLES DE PRODUCCIÓN
# =============================================================================
# NO subas este archivo con valores reales al repositorio.
# Copia este archivo a .env en el VPS y reemplaza cada <...> con el valor real.
#
# Generar secretos aleatorios:
#   openssl rand -base64 32
# =============================================================================

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production
FRONTEND_URL=https://subastasgeek.com
API_URL=https://subastasgeek.com/api

# ── Base de datos ──────────────────────────────────────────────────────────────
POSTGRES_USER=subastas
POSTGRES_PASSWORD=<openssl rand -base64 32>
POSTGRES_DB=subastas
# DATABASE_URL se construye automáticamente en docker-compose.yml a partir de las variables anteriores

# ── Redis ──────────────────────────────────────────────────────────────────────
# Se configura automáticamente en docker-compose.yml

# ── Seguridad ──────────────────────────────────────────────────────────────────
SECRET_KEY=<openssl rand -base64 32>
CSRF_SECRET=<openssl rand -base64 32>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Stripe (producción — obtener en dashboard.stripe.com) ─────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@subastasgeek.com

# ── Storage ────────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/uploads

# ── Observabilidad ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_SERVICE_NAME=subastas-api
# OTEL_EXPORTER_OTLP_ENDPOINT=   # Dejar vacío si no usas observabilidad externa

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Obtener en: console.cloud.google.com → APIs & Services → Credentials
# Agregar https://subastasgeek.com en Authorized JavaScript origins
GOOGLE_CLIENT_ID=<client_id>.apps.googleusercontent.com

# ── Firebase (SMS OTP) ────────────────────────────────────────────────────────
# Habilitar: Firebase Console → Authentication → Sign-in method → Phone
# Agregar subastasgeek.com en Authorized domains
# Service account: Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=subastasgeek
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"subastasgeek",...}

# ── Frontend (variables Vite — se hornean en el build) ────────────────────────
VITE_FIREBASE_API_KEY=AIzaSyD3zQOMhfiyJES3ASraklxqY8aGcyLAwYc
VITE_FIREBASE_AUTH_DOMAIN=subastasgeek.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=subastasgeek
VITE_FIREBASE_APP_ID=1:360011789521:web:a88beee1a03266309281f0
VITE_WS_URL=wss://subastasgeek.com/ws

# ── Límites LFPIORPI (MXN) ────────────────────────────────────────────────────
DEPOSIT_PER_EVENT_CAP=60000
DEPOSIT_30D_CAP=60000
DEPOSIT_ANNUAL_CAP=180000

# ── Penalizaciones ────────────────────────────────────────────────────────────
PENALTY_ENABLED=true
PENALTY_PERCENT=10.0
PAYMENT_WINDOW_HOURS=48

# ── KYC progresivo ────────────────────────────────────────────────────────────
KYC_BID_THRESHOLD=500.0
