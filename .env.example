# =============================================================================
# Base de Datos
# =============================================================================
POSTGRES_USER=subastas
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=subastas
DATABASE_URL=postgresql+asyncpg://subastas:devpassword@db:5432/subastas

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Seguridad / Auth
# =============================================================================
SECRET_KEY=change-me-in-production-use-openssl-rand-base64-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CSRF
CSRF_SECRET=another-secret-for-csrf-change-in-prod

# =============================================================================
# Stripe Connect Express (México)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# =============================================================================
# Storage
# =============================================================================
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/uploads

# =============================================================================
# Observabilidad
# =============================================================================
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=subastas-api

# =============================================================================
# App
# =============================================================================
APP_ENV=development
FRONTEND_URL=http://localhost
API_URL=http://localhost/api

# Topes LFPIORPI (MXN)
DEPOSIT_PER_EVENT_CAP=60000
DEPOSIT_30D_CAP=60000
DEPOSIT_ANNUAL_CAP=180000

# Payment & penalties
PAYMENT_WINDOW_HOURS=48
PENALTY_ENABLED=false
PENALTY_PERCENT=10.0

# =============================================================================
# Email (Resend - free tier 100/day)
# =============================================================================
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@subastas.example.com

# =============================================================================
# Frontend (Vite)
# =============================================================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
